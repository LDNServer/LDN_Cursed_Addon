{
    "format_version": "1.16.210",
    "minecraft:entity": {
        "description": {
            "identifier": "ldns:boss_trophy",
            "is_spawnable": false,
            "is_summonable": true,
            "is_experimental": false
        },
        "component_groups": {
            "despawn": {
                "minecraft:instant_despawn": {}
            },
            "skin_normal": {
                "minecraft:variant": {
                    "value": 0
                }
            },
            "skin_mad": {
                "minecraft:variant": {
                    "value": 1
                }
            },
            "skin_halloween": {
                "minecraft:variant": {
                    "value": 2
                }
            }
        },
        "components": {
            "minecraft:interact": {
                "interactions": [
                    {
                        "on_interact": {
                            "filters": {
                                "all_of": [
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "player"
                                    },
                                    {
                                        "test": "is_sneaking",
                                        "subject": "other",
                                        "operator": "equals",
                                        "value": false
                                    }
                                ]
                            },
                            "event": "ldns:despawn",
                            "target": "self"
                        },
                        "spawn_items": {
                            "table": "loot_tables/entities/boss_trophy.json"
                        },
                        "swing": true,
                        "interact_text": "Break"
                    },
                    {
                        "on_interact": {
                            "filters": {
                                "all_of": [
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "player"
                                    },
                                    {
                                        "test": "is_sneaking",
                                        "subject": "other",
                                        "operator": "equals",
                                        "value": true
                                    }
                                ]
                            },
                            "event": "switch_skin",
                            "target": "self"
                        },
                        "interact_text": "Toggle"
                    }
                ]
            },
            "minecraft:scale": {
                "value": 0.5
            },
            "minecraft:is_stackable": {},
            "minecraft:type_family": {
                "family": [
                    "armor_stand",
                    "mob"
                ]
            },
            "minecraft:collision_box": {
                "width": 0.8,
                "height": 2.8
            },
            "minecraft:damage_sensor": {
                "triggers": {
                    "cause": "all",
                    "deals_damage": false
                }
            },
            "minecraft:health": {
                "value": 6,
                "max": 6
            },
            "minecraft:knockback_resistance": {
                "value": 1
            },
            "minecraft:loot": {
                "table": "loot_tables/empty.json"
            },
            "minecraft:nameable": {},
            "minecraft:persistent": {},
            "minecraft:physics": {},
            "minecraft:pushable": {
                "is_pushable": false,
                "is_pushable_by_piston": true
            },
            "minecraft:conditional_bandwidth_optimization": {}
        },
        "events": {
            "minecraft:entity_spawned": {
                "add": {
                    "component_groups": [
                        "skin_normal"
                    ]
                },
                "sequence": [
                    {
                      "run_command": {
                        "command": [
                          "tp @s ~ ~ ~ facing @p",
                          "execute @s[rym=-23,ry=22] ~ ~ ~ tp @s ~ ~ ~ 0 ~",
                          "execute @s[rym=22,ry=67] ~ ~ ~ tp @s ~ ~ ~ 45 ~",
                          "execute @s[rym=67,ry=112] ~ ~ ~ tp @s ~ ~ ~ 90 ~",
                          "execute @s[rym=112,ry=157] ~ ~ ~ tp @s ~ ~ ~ 135 ~",
                          "execute @s[rym=157,ry=-158] ~ ~ ~ tp @s ~ ~ ~ 180 ~",
                          "execute @s[rym=-158,ry=-113] ~ ~ ~ tp @s ~ ~ ~ -135 ~",
                          "execute @s[rym=-113,ry=-68] ~ ~ ~ tp @s ~ ~ ~ -90 ~",
                          "execute @s[rym=-68,ry=-23] ~ ~ ~ tp @s ~ ~ ~ -45 ~"
                        ],
                        "target": "self"
                      }
                    }
                  ]
            },
            "switch_skin": {
                "randomize": [
                    {
                        "weight": 10,
                        "add": {
                            "component_groups": [
                                "skin_normal"
                            ]
                        },
                        "remove": {
                            "component_groups": [
                                "skin_mad",
                                "skin_halloween"
                            ]
                        }
                    },
                    {
                        "weight": 10,
                        "add": {
                            "component_groups": [
                                "skin_mad"
                            ]
                        },
                        "remove": {
                            "component_groups": [
                                "skin_normal",
                                "skin_halloween"
                            ]
                        }
                    },
                    {
                        "weight": 10,
                        "add": {
                            "component_groups": [
                                "skin_halloween"
                            ]
                        },
                        "remove": {
                            "component_groups": [
                                "skin_normal",
                                "skin_mad"
                            ]
                        }
                    }
                ]
            },
            "ldns:despawn": {
                "add": {
                    "component_groups": [
                        "despawn"
                    ]
                }
            }
        }
    }
}
