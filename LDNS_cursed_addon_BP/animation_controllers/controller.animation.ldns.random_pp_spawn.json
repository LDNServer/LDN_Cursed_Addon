{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.ldns.random_pp_spawn": {
            "states": {
                "default": {
                    "transitions": [
                        {
                            "ldns.pp_spawn": "math.mod(query.life_time,5) == math.die_roll_integer(1,0,16450)"
                        }
                    ]
                },
                "ldns.pp_spawn": {
                    "transitions": [
                        {
                            "default": "variable.time_pp_spawn = (variable.time_pp_spawn ?? 0) ; variable.time_pp_spawn = variable.time_pp_spawn < 56201 ? variable.time_pp_spawn + 1:0;return variable.time_pp_spawn == 0;"
                        }
                    ],
                    "on_entry": [
                        "/execute if score hour SystemClock matches 12..24 run playsound mob.spider.say @s ~ ~ ~ 1.00 0.25 1.00",
                        "/execute if score hour SystemClock matches 12..24 summon ldns:pp ~ ~1 ~"
                    ]
                }
            }
        }
    }
}