{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.ldns.random_sign_1": {
            "states": {
                "default": {
                    "transitions": [
                        {
                            "ldns.place_random_sign_1": "math.mod(query.life_time,5) == math.die_roll_integer(1,0,300)"
                        }
                    ]
                },
                "ldns.place_random_sign_1": {
                    "transitions": [
                        {
                            "ldns.timer": "variable.time_sign_1 = (variable.time_sign_1 ?? 0) ; variable.time_sign_1 = variable.time_sign_1 < 10 ? variable.time_sign_1 + 1:0;return variable.time_sign_1 == 0;"
                        }
                    ],
                    "on_entry": [
                        "/execute @s ^ ^ ^-10 summon ldns:sign_ground_execute ~ ~ ~ ",
                        "/tellraw @s[tag=debug_log] {\"rawtext\":[{\"text\":\"【ADD-ON】Debug - States (controller.animation.ldns.random_sign_1) : ldns.place_random_sign_1 \"}]}"
                    ]
                },
                "ldns.timer": {
                    "transitions": [
                        {
                            "default": "variable.time_sign_1 = (variable.time_sign_1 ?? 0) ; variable.time_sign_1 = variable.time_sign_1 < 2400 ? variable.time_sign_1 + 1:0;return variable.time_sign_1 == 0;"
                        }
                    ],
                    "on_entry": [
                        "/execute @e[type=ldns:sign_ground_execute,c=1] ~ ~ ~ detect ~ ~ ~ air 0 tag @s add block_placed",
                        "/execute @e[type=ldns:sign_ground_execute,c=1,tag=block_placed] ~ ~ ~ detect ~ ~-1 ~ air 0 tag @s remove block_placed",
                        "/execute @e[type=ldns:sign_ground_execute,c=1,tag=block_placed] ~ ~ ~ structure load random_sign_1 ~ ~ ~ 0_degrees"
                    ],
                    "on_exit": [
                        "/tellraw @s[tag=debug_log] {\"rawtext\":[{\"text\":\"【ADD-ON】Debug - States (controller.animation.ldns.random_sign_1) : default \"}]}"
                    ]
                }
            }
        }
    }
}
