{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.ldns.bomber_dungeon_player_checker": {
            "states": {
                "default": {
                    "transitions": [
                        {
                            "ldns.check": "query.time_of_day >= 0"
                        }
                    ]
                },
                "ldns.check": {
                    "transitions": [
                    ],
                    "on_entry":[
                      "/scoreboard objectives add player_check dummy ",
                      "/execute @a[m=survival,r=100] ~ ~ ~ scoreboard players set @e[type=ldns:bomber_dungeon_player_checker_entity,r=128] player_check 1",
                      "/execute @s[scores={player_check=1}] ~ ~ ~ structure load ldns.entity.bomber ~ ~-1 ~"
                    ]
                }
            }
        }
    }
}
