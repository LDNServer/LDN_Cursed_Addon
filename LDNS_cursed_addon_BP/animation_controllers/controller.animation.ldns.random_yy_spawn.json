{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.ldns.random_yy_spawn": {
            "states": {
                "default": {
                    "transitions": [
                        {
                            "ldns.yy_spawn": "math.mod(query.life_time,5) == math.die_roll_integer(1,0,17520)"
                        }
                    ]
                },
                "ldns.yy_spawn": {
                    "transitions": [
                        {
                            "default": "variable.time_yy_spawn = (variable.time_yy_spawn ?? 0) ; variable.time_yy_spawn = variable.time_yy_spawn < 51053 ? variable.time_yy_spawn + 1:0;return variable.time_yy_spawn == 0;"
                        }
                    ],
                    "on_entry": [
                        "/execute if score hour SystemClock matches 0..12 run playsound mob.spider.say @s ~ ~ ~ 1.00 2.15 1.00",
                        "/execute if score hour SystemClock matches 0..12 run summon ldns:yy ~ ~1 ~"
                    ]
                }
            }
        }
    }
}