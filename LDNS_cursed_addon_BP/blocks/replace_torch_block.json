{
    "format_version": "1.16.100",
    "minecraft:block": {
        "description": {
            "identifier": "ldns:replace_torch_block",
            "is_experimental": false,
            "register_to_creative_menu": true
        },
        "components": {
            "minecraft:loot": "loot_tables/blocks/replace_torch_block.json",
            "minecraft:destroy_time": 100,
            "minecraft:explosion_resistance": 100,
            "minecraft:friction": 0.6,
            "minecraft:flammable": {
                "flame_odds": 0,
                "burn_odds": 0
            },
            "minecraft:map_color": "#FFFFFF",
            "minecraft:block_light_absorption": 0,
            "minecraft:block_light_emission": 0,
            "minecraft:ticking": {
                "range": [
                    0,
                    0
                ],
                "looping": false,
                "on_tick": {
                    "event": "break_self",
                    "target": "self",
                    "condition": "query.time_of_day >= 0"
                }
            }
        },
        "events": {
            "break_self": {
                "run_command": {
                    "command": [
                        "fill ~ ~ ~ ~ ~ ~ air 0 destroy"
                    ]
                }
            }
        }
    }
}
